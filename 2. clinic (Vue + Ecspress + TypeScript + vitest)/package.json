{
  "name": "clinic-electron",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsc -p electron/tsconfig.json -w\" \"electron .\"",
    "build": "vite build && tsc -p electron/tsconfig.json",
    "test": "ELECTRON_RUN_AS_NODE=1 ./node_modules/.bin/electron node_modules/vitest/vitest.mjs run",
    "test:run": "ELECTRON_RUN_AS_NODE=1 ./node_modules/.bin/electron node_modules/vitest/vitest.mjs run",
    "start": "electron .",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.0",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "pdfkit": "^0.18.0",
    "sass": "^1.97.3",
    "vite-plugin-vuetify": "^2.1.3",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4",
    "vuetify": "^3.11.8",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.1.2",
    "electron": "^30.5.1",
    "electron-rebuild": "^3.2.9",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^4.0.18"
  }
}
